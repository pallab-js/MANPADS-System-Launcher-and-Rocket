{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MANPADS Control",
  "identifier": "com.manpads.control",
  "version": "1.0.0",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../.next"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "MANPADS Control Panel",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost ws://localhost:*; img-src 'self' data: blob:; font-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com; frame-src 'none'; object-src 'none'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/icon_16.png",
      "icons/icon_32.png",
      "icons/icon_64.png",
      "icons/icon_128.png",
      "icons/icon_256.png",
      "icons/icon_512.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}